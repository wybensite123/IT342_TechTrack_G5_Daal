<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — actual TechTrack logo PNG.
  The PNG is ~2:1 (shield + "TechTrack" wordmark). We place it inside a
  76 x 38dp box centred in the 108dp canvas so:
    • the aspect ratio is preserved (no horizontal stretching),
    • everything stays inside the 66dp safe zone of every OEM mask,
    • the brand-blue background fills the area above and below.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center"
        android:width="76dp"
        android:height="38dp">
        <bitmap
            android:src="@drawable/techtrack_logo"
            android:gravity="fill"
            android:antialias="true"
            android:filter="true" />
    </item>
</layer-list>
